rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Menu Rules
    match /menu/{itemId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(itemId) && isValidMenu(incoming());
      allow update: if isAdmin() && isValidMenu(incoming()) && (
        // Ensure ID doesn't change
        incoming().id == existing().id &&
        // Protect essential fields if needed
        incoming().diff(existing()).affectedKeys().hasOnly(['price', 'prices', 'updatedAt', 'arabicName', 'arabicDescription', 'arabicCategory', 'category', 'name'])
      );
      allow delete: if isAdmin();
    }

    // Admin Rules
    match /admins/{adminId} {
      allow read: if isSignedIn() && (request.auth.uid == adminId || isAdmin());
      allow write: if false;
    }

    function isValidMenu(data) {
      return data.keys().hasAll(['id', 'arabicName', 'arabicCategory', 'category'])
        && data.id is string && data.id.size() <= 128
        && data.arabicName is string && data.arabicName.size() <= 256
        && (data.price == null || (data.price is number && data.price >= 0))
        && (data.prices == null || data.prices is map)
        && data.arabicCategory is string && data.arabicCategory.size() <= 128
        && data.category is string && data.category.size() <= 128;
    }
  }
}
